اُكْتُبْ("بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ")
اُكْتُبْ("═══ اِخْتِبَار اللَّوْح ═══")
اُكْتُبْ("")

# Create a fresh test tablet (separate from the main DB)
كُنْ ل ← لَوْح_مَحْفُوظ(":memory:")

# ─── أَنْشِئْ — CREATE TABLE ──────────────────────────────────
اُكْتُبْ("1. أَنْشِئْ (create):")
ل.أَنْشِئْ("كُتُب", {"id": "INTEGER PRIMARY KEY", "عُنْوَان": "TEXT NOT NULL", "مُؤَلِّف": "TEXT", "سَنَة": "INTEGER"})
كُنْ أَعْمِدَة ← ل.أَعْمِدَة("كُتُب")
لِكُلِّ ع فِي أَعْمِدَة:
    اُكْتُبْ(صِلْ("", ["  عَمُود: ", خُذْ(ع, "name"), " (", خُذْ(ع, "type"), ")"]))

اُكْتُبْ("")

# ─── اِكْتِبْ — INSERT ────────────────────────────────────────
اُكْتُبْ("2. اِكْتِبْ (write):")
ل.اِكْتِبْ("كُتُب", {"عُنْوَان": "الدِّيوَان", "مُؤَلِّف": "الكاشغري", "سَنَة": 1072})
ل.اِكْتِبْ("كُتُب", {"عُنْوَان": "الجَامِع الصَّحِيح", "مُؤَلِّف": "البخاري", "سَنَة": 846})
ل.اِكْتِبْ("كُتُب", {"عُنْوَان": "المَسَالِك والمَمَالِك", "مُؤَلِّف": "ابن خرداذبه", "سَنَة": 870})

# Batch insert
ل.اِكْتِبْ("كُتُب", [{"عُنْوَان": "كِتَاب الحَيَوَان", "مُؤَلِّف": "الجاحظ", "سَنَة": 868}, {"عُنْوَان": "الكِتَاب", "مُؤَلِّف": "سيبويه", "سَنَة": 796}])
كُنْ م ← ل.عُدَّ("كُتُب")
اُكْتُبْ(صِلْ("", ["  كُتِبَ: ", كَلِمَة(م), " سُطُور"]))

اُكْتُبْ("")

# ─── اِقْرَأْ — READ ──────────────────────────────────────────
اُكْتُبْ("3. اِقْرَأْ (read):")
كُنْ كُل ← ل.اِقْرَأْ("كُتُب", تَرْتِيب="سَنَة")
لِكُلِّ ك فِي كُل:
    اُكْتُبْ(صِلْ("", ["  ", كَلِمَة(خُذْ(ك, "سَنَة")), " — ", خُذْ(ك, "عُنْوَان"), " (", خُذْ(ك, "مُؤَلِّف"), ")"]))

اُكْتُبْ("")

# ─── اِبْحَثْ — SEARCH ────────────────────────────────────────
اُكْتُبْ("4. اِبْحَثْ (search):")
كُنْ نَتَائِج ← ل.اِبْحَثْ("كُتُب", "كِتَاب")
اُكْتُبْ(صِلْ("", ["  بَحْث 'كِتَاب': ", كَلِمَة(طُول(نَتَائِج)), " results"]))
لِكُلِّ ن فِي نَتَائِج:
    اُكْتُبْ(صِلْ("", ["    - ", خُذْ(ن, "عُنْوَان")]))

اُكْتُبْ("")

# ─── بَدِّلْ — UPDATE ─────────────────────────────────────────
اُكْتُبْ("5. بَدِّلْ (update):")
كُنْ مُعَدَّل ← ل.بَدِّلْ("كُتُب", {"سَنَة": 1074}, شَرْط="مُؤَلِّف = ?", مُعَامِلَات=("الكاشغري",))
اُكْتُبْ(صِلْ("", ["  rows updated: ", كَلِمَة(مُعَدَّل)]))

# Verify
كُنْ فَحْص ← ل.اِقْرَأْ("كُتُب", شَرْط="مُؤَلِّف = ?", مُعَامِلَات=("الكاشغري",))
لِكُلِّ ف فِي فَحْص:
    اُكْتُبْ(صِلْ("", ["  الكاشغري سَنَة: ", كَلِمَة(خُذْ(ف, "سَنَة"))]))

اُكْتُبْ("")

# ─── عُدَّ — COUNT ─────────────────────────────────────────────
اُكْتُبْ("6. عُدَّ (count):")
كُنْ إِجْمَالِي ← ل.عُدَّ("كُتُب")
كُنْ قَبْل_ألف ← ل.عُدَّ("كُتُب", شَرْط="سَنَة < ?", مُعَامِلَات=(1000,))
اُكْتُبْ(صِلْ("", ["  إِجْمَالِي: ", كَلِمَة(إِجْمَالِي)]))
اُكْتُبْ(صِلْ("", ["  قَبْل 1000 هـ: ", كَلِمَة(قَبْل_ألف)]))

اُكْتُبْ("")

# ─── اِمْحُ — DELETE ──────────────────────────────────────────
اُكْتُبْ("7. اِمْحُ (delete):")
كُنْ مَحْذُوف ← ل.اِمْحُ("كُتُب", شَرْط="id = ?", مُعَامِلَات=(5,))
اُكْتُبْ(صِلْ("", ["  deleted: ", كَلِمَة(مَحْذُوف)]))
كُنْ بَعْد ← ل.عُدَّ("كُتُب")
اُكْتُبْ(صِلْ("", ["  remaining: ", كَلِمَة(بَعْد)]))

