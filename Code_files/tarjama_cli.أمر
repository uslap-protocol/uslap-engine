# بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
# تَرْجَمَة تَفَاعُلِيَّة — Interactive Root Translation Tool
# Type any word in any script → see all connections through the root

اُكْتُبْ("بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ")
اُكْتُبْ("═══ تَرْجَمَة — Root Translation ═══")
اُكْتُبْ("Type any word in any script. Type خُرُوج to exit.")
اُكْتُبْ("")

كُنْ م ← مُتَرْجِم()

كَرِّرْ حَقّ:
    كُنْ كَلِمَة_إِدْخَال ← اِقْرَأْ("تَرْجَمَة> ")

    إِنْ كَلِمَة_إِدْخَال سَوَاء "خُرُوج":
        قِفْ
    إِنْ كَلِمَة_إِدْخَال سَوَاء "exit":
        قِفْ
    إِنْ كَلِمَة_إِدْخَال سَوَاء "":
        اِبْدَأْ

    كُنْ ن ← م.تَرْجِمْ(كَلِمَة_إِدْخَال)

    إِنْ لَا خُذْ(ن، "found"، بَاطِل):
        اُكْتُبْ(صِلْ("", ["  لَمْ يُعْثَر عَلَى جَذْر: ", كَلِمَة_إِدْخَال]))
        اُكْتُبْ("")
        اِبْدَأْ

    # Show root
    كُنْ جَذْر ← خُذْ(ن، "جَذْر"، {})
    إِنْ طُول(جَذْر) فَوْقَ ٠:
        اُكْتُبْ(صِلْ("", ["  جَذْر: ", خُذْ(جَذْر، "root_id"، ""), " ", خُذْ(جَذْر، "حُرُوف"، ""), " — ", خُذْ(جَذْر، "مَعْنَى"، "")]))
        إِنْ خُذْ(جَذْر، "رُمُوز"، ٠) فَوْقَ ٠:
            اُكْتُبْ(صِلْ("", ["  قُرْآن: ", كَلِمَة(خُذْ(جَذْر، "رُمُوز"، ٠)), " رَمْز"]))

    اُكْتُبْ(صِلْ("", ["  أَصْل: ", خُذْ(ن، "orig"، ""), " | مَصْدَر: ", خُذْ(ن، "source"، "")]))

    # Uzbek multi-script
    كُنْ خُطُوط ← خُذْ(ن، "أُزْبَكِي_سِكْرِبْت"، {})
    إِنْ طُول(خُطُوط) فَوْقَ ٠:
        اُكْتُبْ(صِلْ("", ["  أُزْبَكِي: ", خُذْ(خُطُوط، "latin"، ""), " | ", خُذْ(خُطُوط، "cyrillic"، ""), " | ", خُذْ(خُطُوط، "arabic"، "")]))

    # All languages
    كُنْ لُغَات ← ["إِنْجِلِيزِي"، "فَرَنْسِي"، "إِسْبَانِي"، "إِيطَالِي"، "بُرْتُغَالِي"، "أَلْمَانِي"، "لَاتِينِي"، "رُوسِي"، "فَارْسِي"، "مَجَرِي"، "مُنْغُولِي"، "تُرْكِي"، "أُزْبَكِي"، "أَذَرِي"، "قَازَاقِي"، "تَتَرِي"]

    لِكُلِّ لُغَة فِي لُغَات:
        كُنْ قِيَم ← خُذْ(ن، لُغَة، [])
        إِنْ طُول(قِيَم) فَوْقَ ٠:
            إِنْ مِلَفّ_أَمْ_مُجَلَّد(كَلِمَة(قِيَم[٠])) سَوَاء "غَيْر_مَوْجُود":
                اُكْتُبْ(صِلْ("", ["  ", لُغَة, ": ", صِلْ("، "، قِيَم)]))

    # Bitig details
    كُنْ بِيتِيك ← خُذْ(ن، "بِيتِيك"، [])
    إِنْ طُول(بِيتِيك) فَوْقَ ٠:
        لِكُلِّ ب فِي بِيتِيك:
            اُكْتُبْ(صِلْ("", ["  بِيتِيك: ", خُذْ(ب، "term"، ""), " (", خُذْ(ب، "root"، ""), ")"]))

    # Kashgari / Navoi
    إِنْ طُول(خُذْ(ن، "كَاشْغَرِي"، "")) فَوْقَ ٠:
        اُكْتُبْ(صِلْ("", ["  كَاشْغَرِي: ", خُذْ(ن، "كَاشْغَرِي"، "")]))
    إِنْ طُول(خُذْ(ن، "نَوَائِي"، "")) فَوْقَ ٠:
        اُكْتُبْ(صِلْ("", ["  نَوَائِي: ", خُذْ(ن، "نَوَائِي"، "")]))

    اُكْتُبْ("")

م.أَغْلِقْ()
اُكْتُبْ("وَدَاعًا")
