# مَضْرُوب — Recursive Factorial
# Test 2: Proves Turing completeness via recursion

اِعْمَلْ مَضْرُوب(ن):
    إِنْ ن دُونَ ٢:
        اِرْجِعْ ١
    اِرْجِعْ ن * مَضْرُوب(ن - ١)

# حِسَاب — computation
