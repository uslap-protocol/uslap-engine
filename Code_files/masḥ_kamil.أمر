                إِنْ مَجْمُوع فَوْقَ ٠:
                    جَدَاوِل_مُلَوَّثَة ← جَدَاوِل_مُلَوَّثَة + ١

                    لِكُلِّ م فِي مَحْظُورَات:
                        قِ:
                            كُنْ ن ← اللَّوْح.نَفِّذْ(صِلْ("", ["SELECT COUNT(*) as cnt FROM [", ج, "] WHERE LOWER(", نَصّ, ") LIKE '%", م, "%'"]))
                            كُنْ عَدّ ← خُذْ(خُذْ(ن, ٠), "cnt", ٠)
                            إِنْ عَدّ فَوْقَ ٠:
                                إِجْمَالِي_تَلَوُّث ← إِجْمَالِي_تَلَوُّث + عَدّ
                                تَفَاصِيل_تَلَوُّث ← تَفَاصِيل_تَلَوُّث + [{"جَدْوَل": ج, "مُصْطَلَح": م, "عَدَد": عَدّ}]
                        أَنْذِرْ خ:
                            اِبْدَأْ
            أَنْذِرْ خ:
                اِبْدَأْ

اُكْتُبْ(صِلْ("", ["  جَدَاوِل مُلَوَّثَة (بَيَانَات فَقَط): ", كَلِمَة(جَدَاوِل_مُلَوَّثَة)]))
