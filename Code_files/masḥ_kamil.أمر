            لِكُلِّ م فِي مَحْظُورَات:
                شُرُوط ← شُرُوط + [صِلْ("", ["LOWER(", نَصّ, ") LIKE '%", م, "%'"])]
            كُنْ فِلْتَر ← صِلْ(" OR ", شُرُوط)

